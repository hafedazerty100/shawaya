# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in ALL values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key — must be long, random, and unique per deployment.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Shared secret between desktop kiosk and server for sync API authentication.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SYNC_API_KEY=change-me-sync-api-key

# Default admin credentials (used to seed the first admin on first run).
# The admin will be FORCED to change the password on first login.
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# Application mode: "server" or "desktop"
APP_MODE=server

# Server URL (desktop/kiosk mode only) — where the kiosk syncs to.
# Use your ngrok public URL when running publicly, e.g.:
#   SERVER_URL=https://your-shop.ngrok-free.app
SERVER_URL=http://localhost:5000

# Sync interval in seconds (desktop mode only).
SYNC_INTERVAL=30

# Set to 1 to enable Flask debug mode. NEVER set in production.
FLASK_DEBUG=0

# ── ngrok (for public access) ─────────────────────────────────────────────────
# Required only when running run_public.py

# Your ngrok auth token — get it from: https://dashboard.ngrok.com/authtokens
NGROK_AUTH_TOKEN=

# Your free static ngrok domain — get it from: https://dashboard.ngrok.com/domains
# Example: your-shop-name.ngrok-free.app
# Leave blank to get a random URL each run (changes every restart).
NGROK_DOMAIN=
